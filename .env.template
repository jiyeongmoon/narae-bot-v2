# 나래봇(narae-bot) 환경변수 설정 템플릿
# 이 파일을 .env 로 복사하여 실제 값을 입력하세요.

# ── 슬랙 (Slack) ────────────────────────────────────────────────
# 1. api.slack.com > 앱 선택 > OAuth & Permissions > Bot User OAuth Token
SLACK_BOT_TOKEN=xoxb-your-token-here

# 2. api.slack.com > 앱 선택 > Basic Information > Signing Secret
SLACK_SIGNING_SECRET=your-signing-secret-here

# 3. api.slack.com > 앱 선택 > Basic Information > App-Level Tokens (xapp-...)
# connections:write 권한을 가진 토큰을 생성하여 입력하세요.
SLACK_APP_TOKEN=xapp-your-app-token-here

# 3. 매일 17시 일지 작성 알림을 보낼 채널 ID
SLACK_CHANNEL_ID=C0123456789

# 4. 일지 전용 채널 ID (메시지 입력 시 자동으로 노션에 기록)
SLACK_LOG_CHANNEL_ID=C0123456789

# 5. 관리자 슬랙 사용자 ID (선택 사항)
SLACK_ADMIN_ID=U0123456789

# ── 노션 (Notion) ──────────────────────────────────────────────
# 1. notion.so > Settings > Integrations > 새 integration 생성 후 발급
NOTION_TOKEN=secret_your_notion_token_here

# 2. TASK DB ID (하이픈 없이 32자리 문자열)
# 사용자 제공 ID: 76db0dab17c74700acc417c61b91ffca
NOTION_TASK_DB_ID=76db0dab17c74700acc417c61b91ffca

# 3. 사내 인원 DB ID (고도화용)
# 사용자 제공 ID: 336049449b9c8034bdd5ce49180d0ea8
NOTION_USER_DB_ID=336049449b9c8034bdd5ce49180d0ea8

# 4. 일지 전용 DB ID (선택 사항, 이중 기록용)
NOTION_LOG_DB_ID=your-log-db-id-here
