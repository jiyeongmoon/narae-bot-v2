# .env.example
# 이 파일을 복사해서 .env 로 저장 후 실제 값 입력
# .env 는 절대 GitHub에 올리지 마세요 (.gitignore 에 포함됨)

# 슬랙 앱 토큰 (xoxb- 로 시작)
SLACK_BOT_TOKEN=xoxb-여기에-토큰-입력

# 슬랙 서명 시크릿
SLACK_SIGNING_SECRET=여기에-시크릿-입력

# 노션 integration 토큰 (secret_ 로 시작)
NOTION_TOKEN=secret_여기에-토큰-입력

# 노션 TASK DB 페이지 ID (32자리, 하이픈 없이)
NOTION_TASK_DB_ID=여기에-DB-ID-입력

# 일지 전용 슬랙 채널 ID (메시지 자동 기록용)
SLACK_LOG_CHANNEL_ID=여기에-채널-ID-입력

# 일지 전용 DB ID (선택, 설정 시 구조화된 일지 이중 기록)
NOTION_LOG_DB_ID=여기에-일지-DB-ID-입력
